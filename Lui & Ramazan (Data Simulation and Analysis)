# ------------------------------ File helpers ----------------------------------
safe_read_csv <- function(path, ...) {
  if (!file.exists(path)) return(NULL)
  info <- file.info(path)
  if (is.na(info$size) || info$size <= 0) return(NULL)
  tryCatch(read.csv(path, stringsAsFactors = FALSE, ...), error = function(e) NULL)
}

safe_read_rds <- function(path) {
  if (!file.exists(path)) return(NULL)
  info <- file.info(path)
  if (is.na(info$size) || info$size <= 0) return(NULL)
  tryCatch(readRDS(path), error = function(e) NULL)
}

append_csv <- function(path, df) {
  if (is.null(df) || !is.data.frame(df) || nrow(df) == 0) return(invisible(FALSE))
  old <- safe_read_csv(path)
  if (is.null(old) || nrow(old) == 0) {
    write.csv(df, path, row.names = FALSE)
  } else {
    write.csv(rbind(old, df), path, row.names = FALSE)
  }
  invisible(TRUE)
}

append_tsv_line <- function(path, df_line) {
  if (is.null(df_line) || !is.data.frame(df_line) || nrow(df_line) != 1)
    return(invisible(FALSE))
  if (!file.exists(path) || isTRUE(file.info(path)$size == 0))
    write.table(df_line, path, sep = "\t", row.names = FALSE,
                col.names = TRUE,  quote = FALSE)
  else
    write.table(df_line, path, sep = "\t", row.names = FALSE,
                col.names = FALSE, quote = FALSE, append = TRUE)
  invisible(TRUE)
}

# ------------------------------ Metrics --------------------------------------
calc_accuracy <- function(y_true, y_pred) {
  ss_res <- sum((y_true - y_pred)^2)
  ss_tot <- sum((y_true - mean(y_true))^2)
  c(R2   = 1 - ss_res / ss_tot,
    RMSE = sqrt(mean((y_true - y_pred)^2)))
}

# ------------------------------ Jaccard helpers ------------------------------
jaccard_pair <- function(s1, s2) {
  if (!length(s1) && !length(s2)) return(1)
  if (!length(s1) || !length(s2)) return(0)
  length(intersect(s1, s2)) / length(union(s1, s2))
}

pairwise_jaccard_stats <- function(lst) {
  k <- length(lst)
  if (k < 2) return(c(mean = NA_real_, sd = NA_real_))
  jv <- vapply(
    combn(k, 2, simplify = FALSE),
    function(i) jaccard_pair(lst[[i[1]]], lst[[i[2]]]),
    numeric(1)
  )
  c(mean = mean(jv, na.rm = TRUE), sd = sd(jv, na.rm = TRUE))
}

# ------------------------------ Prior helpers ---------------------------------
get_prior_choice <- function(method) {
  switch(
    method,
    normal    = normal(location = 0, scale = 2.5, autoscale = TRUE),
    horseshoe = hs(df = 1, global_df = 1, global_scale = 1,
                   slab_scale = 2.5, slab_df = 4),
    laplace   = lasso(df = 1, location = 0, scale = 1, autoscale = TRUE),
    stop("Unknown method: ", method)
  )
}

# ------------------------------ VB fit ----------------------------------------
# Returns:
#   - pred      : test-set predictions
#   - n_selected: count of selected predictors (intercept & sigma excluded by name)
#   - active    : integer indices of selected predictor columns (1-based, into X)
#   - diag      : diagnostic string
fit_vb_once <- function(X_train, y_train, X_test, method, seed) {
  use_qr   <- nrow(X_train) > ncol(X_train)
  df_train <- data.frame(y = y_train, X_train, check.names = FALSE)
  df_test  <- data.frame(X_test, check.names = FALSE)

  fit <- suppressWarnings(
    stan_glm(
      y ~ .,
      data                 = df_train,
      prior                = get_prior_choice(method),
      algorithm            = "meanfield",
      iter                 = 20000,
      importance_resampling = TRUE,
      QR                   = use_qr,
      seed                 = seed,
      tol_rel_obj          = 0.005
    )
  )

  pred_test  <- colMeans(posterior_epred(fit, newdata = df_test))

  # Exclude intercept and sigma by name — robust regardless of column ordering
  beta_draws   <- as.matrix(fit)
  predictor_cols <- !colnames(beta_draws) %in% c("(Intercept)", "sigma")
  beta_pred    <- beta_draws[, predictor_cols, drop = FALSE]

  ci           <- apply(beta_pred, 2, quantile, probs = c(0.025, 0.975))
  local_active <- which(ci[1, ] > 0 | ci[2, ] < 0)  # column positions in beta_pred
  n_selected   <- length(local_active)

  # Store as named character vector of predictor names for Jaccard
  active_names <- colnames(beta_pred)[local_active]

  diag_str <- sprintf("algorithm=VB_meanfield QR=%s", use_qr)
  rm(beta_draws, beta_pred, fit); gc(verbose = FALSE)

  list(pred = pred_test, n_selected = n_selected,
       active = active_names, diag = diag_str)
}

# ------------------------------ Dataset processor -----------------------------
process_one_dataset <- function(fname, rep, n, layer, method) {
  df <- tryCatch(fread(fname), error = function(e) NULL)
  if (is.null(df))
    return(list(ok = FALSE, reason = paste("Unreadable file:", fname)))
  if (!"y" %in% names(df))
    return(list(ok = FALSE, reason = paste("Missing y column:", fname)))

  y <- df$y
  X <- as.matrix(df[, -1, with = FALSE])
  rm(df)

  if (length(y) != nrow(X))
    return(list(ok = FALSE, reason = paste("Length mismatch in:", fname)))
  if (nrow(X) != n)
    return(list(ok = FALSE, reason = paste("n mismatch, expected", n, "got", nrow(X))))

  set.seed(rep * 100 + n * 10 + layer)
  n_train   <- floor(0.8 * n)
  train_idx <- sample.int(n, size = n_train)
  test_idx  <- setdiff(seq_len(n), train_idx)

  X_train <- X[train_idx, , drop = FALSE]; y_train <- y[train_idx]
  X_test  <- X[test_idx,  , drop = FALSE]; y_test  <- y[test_idx]
  rm(X, y, train_idx, test_idx)

  # Standardise on train statistics
  x_mean <- colMeans(X_train)
  x_sd   <- apply(X_train, 2, sd)
  x_sd[!is.finite(x_sd) | x_sd == 0] <- 1
  X_train <- scale(X_train, center = x_mean, scale = x_sd)
  X_test  <- scale(X_test,  center = x_mean, scale = x_sd)
  storage.mode(X_train) <- "double"
  storage.mode(X_test)  <- "double"

  fit_res <- tryCatch(
    fit_vb_once(X_train, y_train, X_test, method,
                seed = rep * 1000 + n * 10 + layer),
    error = function(e) list(error = conditionMessage(e))
  )

  rm(X_train, y_train, X_test); gc(verbose = FALSE)

  if (!is.null(fit_res$error))
    return(list(ok = FALSE, reason = paste("Fit failed:", fit_res$error)))

  acc <- calc_accuracy(y_test, fit_res$pred)
  rm(y_test); gc(verbose = FALSE)

  list(
    ok  = TRUE,
    row = data.frame(
      method       = method,
      rep          = rep,
      n            = n,
      layer        = layer,
      R2           = unname(acc["R2"]),
      RMSE         = unname(acc["RMSE"]),
      n_selected   = fit_res$n_selected,
      all_selected = as.integer(fit_res$n_selected == P_TOTAL),
      diag         = fit_res$diag,
      stringsAsFactors = FALSE
    ),
    active = list(rep = rep, n = n, layer = layer, active = fit_res$active)
  )
}

