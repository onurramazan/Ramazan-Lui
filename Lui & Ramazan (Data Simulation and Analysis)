  log_file        <- file.path(abs_out_dir, paste0("runlog_", method, ".tsv"))

  existing <- safe_read_csv(per_rep_file)
  if (file.exists(per_rep_file) && is.null(existing)) {
    cat("Existing per-rep file unreadable; removing.\n")
    file.remove(per_rep_file); existing <- NULL
  }

  start_from <- start_rep
  if (!is.null(existing) && nrow(existing) > 0 && "rep" %in% names(existing)) {
    last_rep <- suppressWarnings(max(existing$rep, na.rm = TRUE))
    if (is.finite(last_rep) && last_rep >= start_rep) {
      start_from <- last_rep + 1
      cat("Resuming from replication", start_from, "\n")
    }
  }

  if (start_from > end_rep) { cat("Already completed.\n"); return(TRUE) }

  # Load existing active sets (for resume)
  all_active <- safe_read_rds(active_rds_file)
  if (is.null(all_active) || !is.list(all_active)) all_active <- list()
  if (length(all_active) > 0) {
    keep <- vapply(all_active, function(x)
      is.list(x) && !is.null(x$rep) && length(x$rep) == 1 &&
        is.finite(x$rep) && x$rep < start_from, logical(1))
    all_active <- all_active[keep]
    cat("Loaded", length(all_active), "existing active sets\n")
  }

  todo <- expand.grid(
    rep   = seq.int(start_from, end_rep),
    n     = n_vec_method,
    layer = layer_names,
    KEEP.OUT.ATTRS = FALSE, stringsAsFactors = FALSE
  )
  todo <- todo[order(todo$rep, todo$n, todo$layer), , drop = FALSE]
  cat("Planned datasets:", nrow(todo), "\n")

  for (i in seq_len(nrow(todo))) {
    rep_i <- todo$rep[i]; n_i <- todo$n[i]; layer_i <- todo$layer[i]
    fname <- file.path(abs_data_dir,
                       sprintf("sim_rep%03d_n%d_layer%d.csv", rep_i, n_i, layer_i))

    cat(sprintf("[%s] rep=%03d n=%d layer=%d ... ", method, rep_i, n_i, layer_i))

    if (!file.exists(fname)) {
      cat("missing file\n")
      append_tsv_line(log_file, data.frame(rep = rep_i, n = n_i, layer = layer_i,
        method = method, status = "missing_file", message = fname,
        stringsAsFactors = FALSE))
      next
    }

    res <- process_one_dataset(fname, rep_i, n_i, layer_i, method)

    if (!isTRUE(res$ok)) {
      cat("failed:", res$reason, "\n")
      append_tsv_line(log_file, data.frame(rep = rep_i, n = n_i, layer = layer_i,
        method = method, status = "failed", message = res$reason,
        stringsAsFactors = FALSE))
      gc(verbose = FALSE); next
    }

    append_csv(per_rep_file, res$row)
    all_active[[length(all_active) + 1]] <- res$active
    saveRDS(all_active, active_rds_file)

    append_tsv_line(log_file, data.frame(rep = rep_i, n = n_i, layer = layer_i,
      method = method, status = "ok",
      message = sprintf("R2=%.4f RMSE=%.4f n_selected=%d all=%d",
                        res$row$R2, res$row$RMSE,
                        res$row$n_selected, res$row$all_selected),
      stringsAsFactors = FALSE))
    cat(sprintf("ok [R2=%.4f RMSE=%.4f n_selected=%d all=%d]\n",
                res$row$R2, res$row$RMSE,
                res$row$n_selected, res$row$all_selected))
    rm(res); gc(verbose = FALSE)
  }

  final <- safe_read_csv(per_rep_file)
  if (!is.null(final) && nrow(final) > 0) {
    last_rep <- suppressWarnings(max(final$rep, na.rm = TRUE))
    if (is.finite(last_rep) && last_rep >= end_rep) { cat("Completed.\n"); return(TRUE) }
    cat("Incomplete. Last rep:", last_rep, "\n"); return(FALSE)
  }
  cat("Failed: no valid rows written.\n"); return(FALSE)
}

# ------------------------------ Main loop -------------------------------------
for (method in bayes_methods) {
  process_bayes_method(method, n_vec_method = method_n_vec[[method]])
}

# ------------------------------ Build summaries + Jaccard --------------------
cat("\n", paste(rep("=", 60), collapse = ""), "\n", sep = "")
cat("Building summaries across all methods\n")
cat(paste(rep("=", 60), collapse = ""), "\n", sep = "")

all_per_rep <- do.call(rbind, Filter(
  function(x) !is.null(x) && nrow(x) > 0,
  lapply(bayes_methods, function(m)
    safe_read_csv(file.path(out_dir, paste0("per_rep_", m, ".csv"))))
))

# Compute Jaccard per method from saved RDS files
jaccard_summary <- data.frame()

for (method in bayes_methods) {
  cat("Computing Jaccard stability for:", method, "\n")
  all_active <- safe_read_rds(file.path(out_dir, paste0(method, "_active_sets.rds")))
  if (is.null(all_active) || length(all_active) == 0) {
    cat("  No active sets found — skipping.\n"); next
  }

  active_df <- do.call(rbind, lapply(all_active, function(x)
    data.frame(rep = x$rep, n = x$n, layer = x$layer, stringsAsFactors = FALSE)))
  active_df$active_id <- lapply(all_active, function(x) x$active)

  n_vec_m     <- sort(unique(active_df$n))
  layer_vec_m <- sort(unique(active_df$layer))

  for (n_val in n_vec_m) {
    for (layer_val in layer_vec_m) {
      idx   <- which(active_df$n == n_val & active_df$layer == layer_val)
      stats <- if (length(idx) >= 2)
        pairwise_jaccard_stats(active_df$active_id[idx])
      else
        c(mean = NA_real_, sd = NA_real_)

      jaccard_summary <- rbind(jaccard_summary, data.frame(
        method                 = method,
        n                      = n_val,
        layer                  = layer_val,
        Jaccard_stability_mean = unname(stats["mean"]),
        Jaccard_stability_sd   = unname(stats["sd"]),
        stringsAsFactors = FALSE
      ))
    }
  }
}

if (!is.null(all_per_rep) && nrow(all_per_rep) > 0) {

  write.csv(all_per_rep,
            file.path(out_dir, "per_rep_all.csv"),
            row.names = FALSE)

  summary_df <- all_per_rep %>%
    group_by(method, n, layer) %>%
    summarise(
      n_reps            = n(),
      R2_mean           = mean(R2,           na.rm = TRUE),
      R2_sd             = sd(R2,             na.rm = TRUE),
      RMSE_mean         = mean(RMSE,         na.rm = TRUE),
      RMSE_sd           = sd(RMSE,           na.rm = TRUE),
      n_selected_mean   = mean(n_selected,   na.rm = TRUE),
      n_selected_sd     = sd(n_selected,     na.rm = TRUE),
      n_selected_min    = min(n_selected,    na.rm = TRUE),
      n_selected_max    = max(n_selected,    na.rm = TRUE),
      n_all_selected    = sum(all_selected,  na.rm = TRUE),
      prop_all_selected = mean(all_selected, na.rm = TRUE),
      .groups = "drop"
    ) %>%
    arrange(method, n, layer)

  # Join Jaccard into summary
  if (nrow(jaccard_summary) > 0) {
    summary_df <- summary_df %>%
      left_join(jaccard_summary, by = c("method", "n", "layer"))
  }

  write.csv(as.data.frame(summary_df),
            file.path(out_dir, "summary_all.csv"),
            row.names = FALSE)

  cat("\nSummary table:\n")
  print(as.data.frame(summary_df), row.names = FALSE)

} else {
  cat("No per-replication data found — nothing to summarise.\n")
}

cat("\n", paste(rep("=", 60), collapse = ""), "\n", sep = "")
cat("Done. Output in:", out_dir, "\n")
cat(" - per_rep_<method>.csv         : per-rep results per method\n")
cat(" - <method>_active_sets.rds     : active predictor name sets per rep\n")
cat(" - per_rep_all.csv              : all methods combined\n")
cat(" - summary_all.csv              : accuracy + selection + Jaccard summary\n")
cat(" - runlog_<method>.tsv          : run log per method\n")

